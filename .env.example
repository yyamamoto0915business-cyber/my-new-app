# ===========================================
# MachiGlyph 環境変数テンプレート
# ローカル: .env.local にコピーして使用
# Vercel: Project → Settings → Environment Variables で設定
# ===========================================

# --- サイトURL（本番: https://www.machiglyph.jp）---
# metadataBase / canonical / OG / sitemap の基準
# Production/Preview 両方で設定推奨
NEXT_PUBLIC_SITE_URL=https://www.machiglyph.jp

# --- 必須（Supabase Auth）---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- 運用フェーズで必ず false に ---
# true のまま本番デプロイすると認証が無効になります
AUTH_DISABLED=false
NEXT_PUBLIC_AUTH_DISABLED=false

# --- セッション秘密鍵（本番は必ず設定）---
# 生成: openssl rand -base64 32
AUTH_SECRET=your-auth-secret

# --- メッセージ機能（直接 DB 接続）---
# 未設定時は PostgREST 経由でフォールバック
# SUPABASE_DB_URL=postgresql://postgres.xxx:@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres
# SUPABASE_DB_PASSWORD=your-db-password

# Webhook 用（Stripe等）RLS バイパス。サーバーのみ、絶対にクライアントに露出しないこと
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- MachiGlyph 課金・協賛 ---
APP_URL=https://your-domain.com
TIMEZONE=Asia/Tokyo
# 早期登録締切（3ヶ月以内登録で6ヶ月無料）
EARLYBIRD_SIGNUP_END=2026-06-04T23:59:59+09:00

# Stripe（必須: サブスク・応援・有料イベント・協賛決済）
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# 月980円主催者サブスク Price ID
# STRIPE_PRICE_ORGANIZER_980=price_...

# スポンサー手数料（5%、最低300円）
PLATFORM_FEE_RATE=0.05
PLATFORM_FEE_MIN_JPY=300

# --- オプション: OAuth / メール認証 ---
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_RESEND_KEY=
# AUTH_RESEND_FROM=
# NEXT_PUBLIC_AUTH_GOOGLE=
# NEXT_PUBLIC_AUTH_RESEND=
